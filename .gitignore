## A streamlined .gitignore for modern .NET + Angular projects
## Includes temporary files, build results, and files from popular .NET & Angular tools

# ============ .NET Build Results ============
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
*.snupkg

# .NET Others
~$*
*~
CodeCoverage/
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ============ Angular Build Results ============
node_modules/
.npm/
.yarn/
.ngo/
.ng-cache/
.dist/
.build/
coverage/
.ng-cli-overrides.json
angular.json.tmp

# Angular CLI
.angular/

# TypeScript
*.tsbuildinfo
*.map

# IDE files (optional, uncomment if needed)
# .vscode/
# .idea/

# OS files
.DS_Store
Thumbs.db
